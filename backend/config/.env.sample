PORT=8000
NODE_ENV=DEVELOPMENT

# MongoDB Database URL
DB_URL="mongodb://localhost:27017/swiftcart"

# JSON Web Token (JWT) settings
JWT_SECRET_KEY="your_jwt_secret_key_here"
JWT_EXPIRE="5d"
COOKIE_EXPIRES=5

# SMTP settings for sending emails (e.g. password reset)
SMTP_SERVICE="gmail"
SMTP_MAIL="your_email@gmail.com"
SMTP_PASSWORD="your_app_password"

# Razorpay Payment Gateway credentials
RAZORPAY_API_KEY="your_razorpay_key_id"
RAZORPAY_API_SECRET="your_razorpay_key_secret"

# Cloudinary image hosting credentials
CLOUDINARY_NAME="your_cloudinary_name"
CLOUDINARY_API_KEY="your_cloudinary_api_key"
CLOUDINARY_API_SECRET="your_cloudinary_api_secret"
